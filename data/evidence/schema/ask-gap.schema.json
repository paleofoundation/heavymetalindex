{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schema/ask-gap.schema.json",
  "title": "Ask the Index Evidence Gap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "capture_status",
    "question",
    "role",
    "verb",
    "page_slug",
    "public_answer_status",
    "confidence",
    "priority",
    "claim_needed",
    "evidence_type_needed",
    "blocking_reason",
    "suggested_source_slots",
    "target_pages",
    "current_citations"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^askgap_[a-z0-9]+$" },
    "schema_version": { "type": "integer", "const": 1 },
    "capture_status": {
      "type": "string",
      "enum": [
        "included_in_response",
        "queued_jsonl",
        "response_only_write_failed"
      ]
    },
    "captured_at": { "type": "string", "format": "date-time" },
    "question": { "type": "string", "minLength": 1 },
    "role": { "type": "string" },
    "verb": { "type": "string" },
    "page_slug": { "type": "string" },
    "public_answer_status": {
      "type": "string",
      "enum": ["limited", "blocked", "non_comparable", "private_mode_required"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "insufficient"]
    },
    "priority": { "type": "string", "enum": ["high", "medium", "low"] },
    "ingredient_or_product": { "type": "string" },
    "ingredient_or_product_slug": { "type": "string" },
    "metal_or_analyte": { "type": "string" },
    "metal_or_analyte_slug": { "type": "string" },
    "claim_needed": { "type": "string", "minLength": 1 },
    "evidence_type_needed": {
      "type": "string",
      "enum": [
        "additive_or_bioaccessibility_intervention",
        "comparability_bridge_or_basis_conversion",
        "cross_food_risk_ranking_method",
        "current_regulatory_jurisdiction_list",
        "mitigation_intervention",
        "occurrence_distribution",
        "private_workbench_input",
        "source_ingest_or_synthesis"
      ]
    },
    "blocking_reason": { "type": "string", "minLength": 1 },
    "suggested_source_slots": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "target_pages": {
      "type": "array",
      "items": { "$ref": "#/$defs/page_ref" }
    },
    "current_citations": {
      "type": "array",
      "items": { "$ref": "#/$defs/page_ref" }
    }
  },
  "$defs": {
    "page_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "slug", "url"],
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" }
      }
    }
  }
}
