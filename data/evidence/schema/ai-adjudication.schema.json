{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schemas/ai-adjudication.schema.json",
  "title": "AI adjudication queue row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adjudication_order",
    "priority",
    "machine_task",
    "action_type",
    "product_slug",
    "product_label",
    "metal_species",
    "hmtc_standard_percentile_target",
    "hmtc_standard_statistic",
    "aggregate_hmtc_percentile_status",
    "required_decisions",
    "input_artifacts",
    "guardrails",
    "expected_outputs",
    "confidence_gate",
    "human_exception_trigger",
    "blocks_public_claims",
    "blocks_hmtc_threshold",
    "next_command"
  ],
  "properties": {
    "adjudication_order": {
      "type": "integer",
      "minimum": 1
    },
    "priority": {
      "type": "string",
      "pattern": "^P[0-3]$"
    },
    "machine_task": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "product_slug": {
      "type": "string",
      "minLength": 1
    },
    "product_label": {
      "type": "string",
      "minLength": 1
    },
    "product_standard_scope": {
      "type": "string"
    },
    "product_review_state": {
      "type": "string"
    },
    "metal_species": {
      "type": "string",
      "minLength": 1
    },
    "source_ids": {
      "type": "string"
    },
    "hmtc_standard_percentile_target": {
      "type": "string",
      "minLength": 1
    },
    "hmtc_standard_statistic": {
      "type": "string",
      "minLength": 1
    },
    "aggregate_hmtc_percentile_status": {
      "type": "string",
      "minLength": 1
    },
    "required_decisions": {
      "type": "string",
      "minLength": 1
    },
    "input_artifacts": {
      "type": "string",
      "minLength": 1
    },
    "guardrails": {
      "type": "string",
      "minLength": 1
    },
    "expected_outputs": {
      "type": "string",
      "minLength": 1
    },
    "confidence_gate": {
      "type": "string",
      "minLength": 1
    },
    "human_exception_trigger": {
      "type": "string",
      "minLength": 1
    },
    "blocks_public_claims": {
      "type": "string",
      "enum": ["true", "false"]
    },
    "blocks_hmtc_threshold": {
      "type": "string",
      "enum": ["true", "false"]
    },
    "next_command": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
