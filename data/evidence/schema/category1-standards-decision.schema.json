{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schema/evidence/category1-standards-decision.schema.json",
  "title": "Heavy Metal Index Category 1 Standards Decision Row",
  "type": "object",
  "additionalProperties": false,
  "required": ["category_id", "row_id", "row_slug", "metal_species", "standard_status"],
  "properties": {
    "category_id": { "const": "hmtc-category-1" },
    "row_id": { "type": "string", "pattern": "^hmtc_c1_r[0-9]{2}$" },
    "row_slug": { "type": "string", "minLength": 1 },
    "row_label": { "type": "string" },
    "metal_species": {
      "enum": ["Pb", "Cd", "iAs", "tAs", "tHg", "MeHg", "Ni", "Al", "Sn", "Cr-total", "Cr-VI"]
    },
    "standard_status": {
      "enum": ["draft", "candidate", "needs_review", "approved", "finalized", "superseded", "rejected"]
    },
    "final_standard_ppb": { "type": ["number", "null"], "minimum": 0 },
    "unit": { "type": "string" },
    "basis": { "type": "string" },
    "standard_basis": { "enum": ["clean_p90", "dirty_p10", "independent_p90", "path_b_loq_x5", "manual_override", ""] },
    "standard_path": { "enum": ["Path A", "Path B", "Manual", ""] },
    "approved_by": { "type": "string" },
    "approved_date": { "type": "string" },
    "source_ids": { "type": "string" },
    "notes": { "type": "string" }
  }
}
