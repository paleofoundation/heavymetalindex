{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schema/evidence/source.schema.json",
  "title": "Heavy Metal Index Source Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "review_state",
    "raw_handle",
    "source_title",
    "source_type",
    "evidence_tier",
    "source_page_path",
    "metal_mentions",
    "matrix_mentions"
  ],
  "properties": {
    "source_id": { "type": "string", "minLength": 1 },
    "raw_handle": { "type": ["string", "null"] },
    "raw_path": { "type": ["string", "null"] },
    "source_page_path": { "type": "string", "minLength": 1 },
    "cite_key": { "type": ["string", "null"] },
    "source_title": { "type": ["string", "null"] },
    "source_type": { "type": ["string", "null"] },
    "evidence_tier": { "enum": ["A", "B", "C", null] },
    "license": { "type": ["string", "null"] },
    "sha256": { "type": ["string", "null"] },
    "doi": { "type": ["string", "null"] },
    "year": { "type": ["integer", "null"] },
    "metal_mentions": { "type": "array", "items": { "type": "string" } },
    "matrix_mentions": { "type": "array", "items": { "type": "string" } },
    "statistic_flags": { "type": "array", "items": { "type": "string" } },
    "review_state": {
      "enum": [
        "draft",
        "machine_extracted",
        "needs_review",
        "reviewed",
        "approved_for_internal",
        "approved_for_public",
        "published",
        "rejected",
        "superseded",
        "needs_source",
        "needs_unit_review",
        "needs_legal_review"
      ]
    },
    "extraction_run_id": { "type": ["string", "null"] },
    "extraction_timestamp": { "type": ["string", "null"], "format": "date-time" }
  }
}
