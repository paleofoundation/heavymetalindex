{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schema/evidence/claim.schema.json",
  "title": "Heavy Metal Index Claim Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim_id", "claim_class", "review_state", "claim_text", "source_id", "quote_trace"],
  "properties": {
    "claim_id": { "type": "string", "minLength": 1 },
    "claim_class": {
      "enum": [
        "literature_finding",
        "regulatory_limit",
        "toxicology_reference_value",
        "exposure_model",
        "internal_standard_candidate",
        "hmtc_threshold",
        "public_wiki_claim",
        "app_model_assumption"
      ]
    },
    "claim_text": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "value_id": { "type": ["string", "null"] },
    "quote_trace": { "type": "string", "minLength": 1 },
    "page_number": { "type": ["string", "null"] },
    "review_state": {
      "enum": [
        "draft",
        "machine_extracted",
        "needs_review",
        "reviewed",
        "approved_for_internal",
        "approved_for_public",
        "published",
        "rejected",
        "superseded",
        "needs_source",
        "needs_unit_review",
        "needs_legal_review"
      ]
    },
    "public_label": {
      "enum": [
        "Strong occurrence evidence",
        "Reconstructable dataset",
        "Modeled or limited evidence",
        "Context only",
        "Data gap",
        "Rejected/unusable",
        null
      ]
    }
  }
}
