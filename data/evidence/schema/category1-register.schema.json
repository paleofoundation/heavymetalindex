{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schema/evidence/category1-register.schema.json",
  "title": "Heavy Metal Index Category 1 Register Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "category_id",
    "row_id",
    "row_slug",
    "metal_species",
    "evidence_fitness_verdict",
    "public_label",
    "review_state"
  ],
  "properties": {
    "category_id": { "const": "hmtc-category-1" },
    "category_label": { "const": "Infant and Child Foods" },
    "row_id": { "type": "string", "pattern": "^hmtc_c1_r[0-9]{2}$" },
    "row_slug": { "type": "string", "minLength": 1 },
    "row_label": { "type": "string", "minLength": 1 },
    "metal_species": {
      "enum": ["Pb", "Cd", "iAs", "tAs", "tHg", "MeHg", "Ni", "Al", "Sn", "Cr-total", "Cr-VI"]
    },
    "evidence_fitness_verdict": { "enum": ["EF-1", "EF-2", "EF-3", "EF-4", "EF-5", "EF-X"] },
    "public_label": {
      "enum": [
        "Strong occurrence evidence",
        "Reconstructable dataset",
        "Modeled or limited evidence",
        "Context only",
        "Data gap",
        "Rejected/unusable"
      ]
    },
    "review_state": {
      "enum": [
        "draft",
        "machine_extracted",
        "needs_review",
        "reviewed",
        "approved_for_internal",
        "approved_for_public",
        "published",
        "rejected",
        "superseded",
        "needs_source",
        "needs_unit_review",
        "needs_legal_review"
      ]
    },
    "source_count": { "type": "integer", "minimum": 0 },
    "notes": { "type": "string" }
  }
}
