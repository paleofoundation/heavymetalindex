{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schema/evidence/review-event.schema.json",
  "title": "Heavy Metal Index Review Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "record_id", "record_type", "review_state", "reviewer_role", "timestamp"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "record_id": { "type": "string", "minLength": 1 },
    "record_type": { "enum": ["source", "value", "claim", "category1_cell"] },
    "review_state": {
      "enum": [
        "draft",
        "machine_extracted",
        "needs_review",
        "reviewed",
        "approved_for_internal",
        "approved_for_public",
        "published",
        "rejected",
        "superseded",
        "needs_source",
        "needs_unit_review",
        "needs_legal_review"
      ]
    },
    "reviewer_role": {
      "enum": [
        "researcher",
        "scientific_reviewer",
        "regulatory_reviewer",
        "editorial_reviewer",
        "legal_reviewer",
        "publisher",
        "admin",
        "system"
      ]
    },
    "reviewer_id": { "type": ["string", "null"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "notes": { "type": ["string", "null"] }
  }
}
