{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heavymetalindex.com/schema/evidence/value.schema.json",
  "title": "Heavy Metal Index Value Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "value_id",
    "source_id",
    "claim_class",
    "review_state",
    "evidence_fitness_verdict",
    "public_label"
  ],
  "properties": {
    "value_id": { "type": "string", "minLength": 1 },
    "source_id": { "type": "string", "minLength": 1 },
    "claim_class": {
      "enum": [
        "literature_finding",
        "regulatory_limit",
        "toxicology_reference_value",
        "exposure_model",
        "internal_standard_candidate",
        "hmtc_threshold",
        "public_wiki_claim",
        "app_model_assumption"
      ]
    },
    "metal_species": { "type": ["string", "null"] },
    "product_matrix": { "type": ["string", "null"] },
    "basis": { "enum": ["wet_weight", "dry_weight", "as_sold", "reconstituted", "not_reported", null] },
    "statistic_type": { "type": ["string", "null"] },
    "original_value": { "type": ["number", "null"] },
    "original_unit": { "type": ["string", "null"] },
    "normalized_value": { "type": ["number", "null"] },
    "normalized_unit": { "type": ["string", "null"] },
    "quote_trace": { "type": ["string", "null"] },
    "page_number": { "type": ["string", "null"] },
    "table_number": { "type": ["string", "null"] },
    "evidence_fitness_verdict": { "enum": ["EF-1", "EF-2", "EF-3", "EF-4", "EF-5", "EF-X"] },
    "public_label": {
      "enum": [
        "Strong occurrence evidence",
        "Reconstructable dataset",
        "Modeled or limited evidence",
        "Context only",
        "Data gap",
        "Rejected/unusable"
      ]
    },
    "review_state": {
      "enum": [
        "draft",
        "machine_extracted",
        "needs_review",
        "reviewed",
        "approved_for_internal",
        "approved_for_public",
        "published",
        "rejected",
        "superseded",
        "needs_source",
        "needs_unit_review",
        "needs_legal_review"
      ]
    }
  }
}
